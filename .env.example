# Copy to .env and adjust. .env is git-ignored.

# Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
SECRET_KEY=change-me

DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Leave unset to use SQLite (db.sqlite3). For Postgres:
# DATABASE_URL=postgres://user:password@localhost:5432/ark_yandex

# WS channel layer (live map / dispatcher feed / notifications). Leave unset for the
# in-memory layer (single process only); set for Redis across runserver + worker.
# REDIS_URL=redis://localhost:6379/0

# Routing engine for the live map polyline. Defaults to OSRM's public demo server
# (rate-limited/flaky → route falls back to a straight line over buildings). Point at
# a self-hosted OSRM for real road-snapped routes. Do NOT set it empty (that disables
# routing → permanent straight line).
# CAR_ORDER_OSRM_URL=http://localhost:5000
