# Copy to .env and adjust. .env is git-ignored. Read by python-decouple.

# Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
SECRET_KEY=change-me

DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Primary database — PostgreSQL (POSTGRES_* style, same as ark-backend). For local
# (non-Docker) runs set POSTGRES_HOST=localhost; docker-compose sets it to the `db`
# service name. The geo DB inherits USER/PASSWORD unless GEO_POSTGRES_* overrides them.
POSTGRES_DB=ark_yandex
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Telemetry database — PostGIS. Holds ONLY DriverPosition + OrderLiveLocation
# (routed by car_orders.routers.GeoRouter). Needs the postgis extension (created by
# migration 0026 / the postgis/postgis image). Migrate it with:
#   python manage.py migrate --database=geo
GEO_POSTGRES_DB=ark_geo
GEO_POSTGRES_HOST=localhost
# GEO_POSTGRES_USER / GEO_POSTGRES_PASSWORD / GEO_POSTGRES_PORT — default to POSTGRES_*.

# WS channel layer (live map / dispatcher feed / notifications). Leave REDIS_HOST
# unset for the in-memory layer (single process only). REQUIRED in prod — gunicorn
# runs >1 UvicornWorker, so groups must cross processes via Redis.
# REDIS_HOST=localhost
# REDIS_PORT=6379

# Routing engine for the live map polyline. Defaults to OSRM's public demo server
# (rate-limited/flaky → route falls back to a straight line over buildings). Point at
# a self-hosted OSRM for real road-snapped routes. Do NOT set it empty (that disables
# routing → permanent straight line).
# CAR_ORDER_OSRM_URL=http://localhost:5000
